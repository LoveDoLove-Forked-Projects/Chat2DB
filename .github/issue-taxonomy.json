  "priorities": [
    {
      "name": "P0 Critical",
      "color": "RED",
      "description": "Security, data loss, startup failure, or release blocker with no workaround",
      "responseTarget": "Same day"
    },
    {
      "name": "P1 High",
      "color": "ORANGE",
      "description": "Core workflow unavailable for many users with no reliable workaround",
      "responseTarget": "2 business days"
    },
    {
      "name": "P2 Normal",
      "color": "YELLOW",
      "description": "Normal confirmed issue or feature with limited impact or a workaround",
      "responseTarget": "7 calendar days"
    },
    {
      "name": "P3 Low",
      "color": "GRAY",
      "description": "Edge case, minor experience issue, or low-priority improvement",
      "responseTarget": "Monthly backlog review"
    }
  ],
